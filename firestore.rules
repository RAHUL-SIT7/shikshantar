rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Admin based on email or user doc role
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'rahulsah4534@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'teacher'
      );
    }
    
    // 1. Users Security (DO NOT CHANGE)
    match /users/{userId} {
        allow read: if request.auth != null;
        
        allow update: if isAdmin() || (request.auth.uid == userId && resource != null && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
                     
        allow create: if (request.auth != null && request.resource.data.role == "student") 
                     || isAdmin();
        
        allow delete: if isAdmin();
    }

    // 2. Settings / Site content (Only Admin can edit)
    match /settings/{document=**} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // 3. UPDATED: Gallery & Images - NOW ONLY ADMIN can add or delete photos
    match /school_data/{document=**} {
        allow read: if true;
        allow write: if isAdmin();
    }
    
    // 4. Academic Results - BOTH Admin & Teachers can manage and publish results
    match /results/{document=**} {
        // Any logged-in student/user can read results
        allow read: if request.auth != null; 
        
        // Admins AND Teachers can add, edit, or delete results
        allow write: if isAdmin() || isTeacher();
    }
    
    // Used in the app for per-student secure result fetching
    match /results_secure/{studentId} {
      allow read: if isSignedIn() && (request.auth.uid == studentId || isAdmin() || isTeacher());
      allow write: if isAdmin() || isTeacher();
    }

    // App core collections for results
    match /resultSummary/{document=**} {
        allow read: if true;
        allow write: if isAdmin() || isTeacher();
    }

    match /exams/{document=**} {
        allow read: if true;
        allow write: if isAdmin() || isTeacher();
    }

    // 5. Secure Public Admission Forms
    match /admissions/{document=**} {
        // Anyone can submit a form
        allow create: if true; 
        
        // Only Admins can view or delete submitted forms
        allow read, update, delete: if isAdmin();
    }
    
    // ----- RESTORED REQUIRED APP COLLECTIONS -----

    // Notices / Notice Board
    match /notices/{document=**} {
      allow read: if true;
      allow create, delete: if isAdmin() || isTeacher();
      allow update: if isAdmin() || isTeacher() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
      );
    }
    
    // Financial Data (Fee Management)
    match /feeStructure/{document=**} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    match /studentFees/{document=**} {
        allow read: if isAdmin() || (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid);
        allow write: if isAdmin();
    }

    match /financial_students/{studentId} {
      allow read: if isSignedIn() && (request.auth.uid == studentId || isAdmin());
      allow write: if isAdmin();
    }

    match /financial_transactions/{transactionId} {
      // Students can only read their own transactions
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
