rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student')
        : 'student';
    }

    function isSafeAdmin() {
      return request.auth != null && (
        ('email' in request.auth.token && request.auth.token.email == 'rahulsah4534@gmail.com') ||
        (getUserRole() == 'admin')
      );
    }

    function isSafeTeacher() {
      return request.auth != null && (
        (getUserRole() == 'teacher')
      );
    }

    match /users/{userId} {
        // allow any signed in user to read to prevent complex read failures on their own profile
        allow read: if isSignedIn();
        allow update: if isSafeAdmin() || (isSignedIn() && request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        ));
        allow create: if isSignedIn();
        allow delete: if isSafeAdmin();
    }

    match /settings/{document=**} {
        allow read: if true;
        allow write: if isSafeAdmin();
    }
    
    match /exams/{document=**} {
        // To prevent onSnapshot error temporarily, allow reads for all authenticated users seamlessly
        allow read: if true;
        allow write: if isSafeAdmin() || isSafeTeacher();
    }

    match /results/{document=**} {
        allow read: if true;
        allow write: if isSafeAdmin() || isSafeTeacher();
    }

    match /resultSummary/{document=**} {
        allow read: if true;
        allow write: if isSafeAdmin() || isSafeTeacher();
    }

    match /feeStructure/{feeId} {
        allow read: if isSignedIn();
        allow write: if isSafeAdmin();
    }

    match /studentFees/{feeId} {
        allow read: if isSafeAdmin() || (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid);
        allow write: if isSafeAdmin();
    }

    match /notices/{document=**} {
      allow read: if true;
      allow write: if isSafeAdmin() || isSafeTeacher();
    }

    match /admissions/{document=**} {
        allow create: if true; 
        allow read, update, delete: if isSafeAdmin();
    }

    match /transactions/{transactionId} {
        allow read: if isSafeAdmin() || (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid);
        allow write: if isSafeAdmin();
    }

    match /school_data/{document=**} {
        allow read: if true;
        allow write: if isSafeAdmin();
    }

    match /financial_students/{document=**} {
        allow read, write: if isSafeAdmin();
    }

    match /financial_transactions/{document=**} {
        allow read, write: if isSafeAdmin();
    }

    match /my_test_collection/{doc=**} {
        allow read: if true;
    }
  }
}
