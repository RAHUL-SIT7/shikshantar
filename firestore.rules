rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'rahulsah4534@gmail.com') ||
        isRole('admin')
      );
    }

    function isTeacher() {
      return isSignedIn() && isRole('teacher');
    }

    function isOwner(studentId) {
      return isSignedIn() && request.auth.uid == studentId;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // School Data
    match /school_data/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Results
    match /results/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /years/{year}/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /examConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /results_secure/{studentId} {
      allow read: if isOwner(studentId) || isAdmin() || isTeacher();
      allow write: if isAdmin() || isTeacher();
    }

    match /resultSummary/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    match /exams/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // Admissions
    match /admissions/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Notices
    match /notices/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // Fee Management
    match /feeStructure/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /studentFees/{feeDocId} {
      allow read: if isAdmin() ||
                  (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid) ||
                  (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow write: if isAdmin();
    }

    match /financial_students/{studentId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow write: if isAdmin();
    }

    match /financial_transactions/{transactionId} {
      allow read: if isAdmin() ||
                  (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid) ||
                  (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow write: if isAdmin();
    }

    // Transactions (alternate collection name)
    match /transactions/{transactionId} {
      allow read: if isAdmin() ||
                  (isSignedIn() && resource.data.get('studentId', '') == request.auth.uid) ||
                  (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow write: if isAdmin();
    }

    match /salary_structures/{teacherId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == teacherId);
      allow write: if isAdmin();
    }

    match /salary_records/{recordId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    match /trash/{document=**} {
      allow read, write: if isAdmin() || isTeacher();
    }
  }
}
